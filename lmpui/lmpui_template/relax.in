log output/relax.log
processors * * *
dimension 3
boundary p p p
units metal
atom_style atomic
atom_modify map array

neighbor 1.0 nsq
neigh_modify once no every 1 delay 0 check yes

read_data potential/bottom_Al.lmp
read_data potential/top_Cu.lmp add append shift 0.0 0.0 104.6

group Al type 1
group Cu type 2

mass 1 26.98153860
mass 2 63.54600000

pair_style eam/alloy
pair_coeff * * potential/al-cu-set.eam.alloy Al Cu

neighbor 2 bin
neigh_modify every 10 delay 0 check no

# regions & groups
variable Ztop equal (zhi-10)
variable Zbot equal (zlo+20)

region upper block INF INF INF INF ${Ztop} INF units box
group upper region upper
group Cu_active subtract Cu upper

region lower block INF INF INF INF INF ${Zbot} units box
group lower region lower
group Al_active subtract Al lower

group boundary union lower upper
group mobile subtract all boundary

# computes
compute ke all ke/atom
fix aveKE all ave/atom 1 1000 10000 c_ke
variable AtomTemp atom "2*f_aveKE/(3*8.617333e-5)"

timestep 0.002
thermo 5000
thermo_style custom step temp pe ke etotal press

dump d_relax all custom 5000 output/dump_relax.lammpstrj id type x y z

velocity all create 300 6767676767 rot yes dist gaussian

min_style cg
fix boxrelax all box/relax aniso 0.0
minimize 1e-6 1e-8 50000 50000
unfix boxrelax

fix freeze boundary setforce 0.0 0.0 0.0
fix relax_npt mobile npt temp 300 300 0.2 aniso 0.0 0.0 1.0

run 150000

unfix relax_npt
unfix freeze
undump d_relax

write_restart restart/restart.relax
